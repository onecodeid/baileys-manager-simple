<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsApp Device Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font@7.x/css/materialdesignicons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/vuetify@3.5.2/dist/vuetify.min.css" rel="stylesheet">
</head>

<body>
    <div id="app"></div>

    <script src="https://cdn.jsdelivr.net/npm/vue@3.4.15/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vuetify@3.5.2/dist/vuetify.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vuex@4.1.0/dist/vuex.global.prod.js"></script>

    <script>
        const { createApp, ref, computed, onMounted, onUnmounted } = Vue;
        const { createVuetify } = Vuetify;
        const { createStore } = Vuex;

        // PHP proxy on the same domain — avoids CORS to localhost
        const API_BASE_URL = '/baileys-proxy.php';

        // --- VUEX STORE ---
        const store = createStore({
            state() {
                return {
                    sessionId: 'sales_line',
                    status: 'DISCONNECTED',
                    qrCodeData: null,
                    pollingInterval: null
                }
            },
            mutations: {
                SET_STATUS(state, payload) { state.status = payload; },
                SET_QR(state, payload) { state.qrCodeData = payload; },
                SET_POLLING(state, payload) { state.pollingInterval = payload; }
            },
            actions: {
                async initializeSession({ state, dispatch }) {
                    dispatch('updateStatus', 'CONNECTING');
                    try {
                        await fetch(`${API_BASE_URL}?path=/api/session/start`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ sessionId: state.sessionId })
                        });
                        dispatch('startPolling');
                    } catch (error) {
                        console.error("Failed to boot channel connection", error);
                        dispatch('updateStatus', 'DISCONNECTED');
                    }
                },
                async checkStatus({ state, commit, dispatch }) {
                    try {
                        const res = await fetch(`${API_BASE_URL}?path=/api/session/status/${state.sessionId}`);
                        const data = await res.json();

                        commit('SET_STATUS', data.status);
                        commit('SET_QR', data.qr);

                        if (data.status === 'SCAN_QR' || data.status === 'CONNECTING') {
                            if (!state.pollingInterval) dispatch('startPolling');
                        } else {
                            dispatch('stopPolling');
                        }
                    } catch (err) {
                        console.error("Error polling session metrics", err);
                    }
                },
                startPolling({ dispatch, commit }) {
                    dispatch('stopPolling');
                    const interval = setInterval(() => {
                        dispatch('checkStatus');
                    }, 3000);
                    commit('SET_POLLING', interval);
                },
                stopPolling({ state, commit }) {
                    if (state.pollingInterval) {
                        clearInterval(state.pollingInterval);
                        commit('SET_POLLING', null);
                    }
                },
                updateStatus({ commit }, status) {
                    commit('SET_STATUS', status);
                }
            }
        });

        const vuetify = createVuetify();

        // --- VUE APPLICATION ---
        const app = createApp({
            template: `
      <v-app theme="light">
        <v-main class="bg-grey-lighten-4 d-flex align-center justify-center">
          <v-card width="450" class="pa-6 rounded-lg elevation-4">
            
            <v-card-item class="text-center">
              <v-icon icon="mdi-whatsapp" color="success" size="64" class="mb-2"></v-icon>
              <v-card-title class="text-h5 font-weight-bold">WhatsApp Integrator</v-card-title>
              <v-card-subtitle>Session ID: {{ sessionId }}</v-card-subtitle>
            </v-card-item>

            <v-divider class="my-4"></v-divider>

            <div class="text-center my-6">
              <p class="text-subtitle-1 mb-2">Current Connection State:</p>
              <v-chip :color="statusColor" class="font-weight-black text-uppercase px-4 py-2" size="large">
                <v-icon start :icon="statusIcon"></v-icon>
                {{ currentStatus }}
              </v-chip>
            </div>

            <v-card-text class="d-flex flex-column align-center justify-center" style="min-height: 220px;">
              
              <v-btn 
                v-if="currentStatus === 'DISCONNECTED'" 
                color="success" 
                size="large" 
                prepend-icon="mdi-link-variant"
                @click="connectDevice"
                block
              >
                Connect Number
              </v-btn>

              <div v-if="currentStatus === 'CONNECTING'" class="text-center">
                <v-progress-circular indeterminate color="success" size="50" class="mb-3"></v-progress-circular>
                <p class="text-body-2 text-grey-darken-1">Checking system sync keys...</p>
              </div>

              <div v-if="currentStatus === 'SCAN_QR' && qrCode" class="text-center">
                <p class="text-caption text-grey-darken-2 mb-3">Scan this code using linked devices menu:</p>
                <v-img :src="qrCode" width="200" height="200" class="mx-auto elevation-2 rounded"></v-img>
              </div>

              <div v-if="currentStatus === 'CONNECTED'" class="text-center">
                <v-icon icon="mdi-check-circle" color="success" size="56" class="mb-2"></v-icon>
                <p class="text-success font-weight-bold">Line deployment active and listening for API pushes!</p>
              </div>

            </v-card-text>
          </v-card>
        </v-main>
      </v-app>
    `,
            setup() {
                const sessionId = computed(() => store.state.sessionId);
                const currentStatus = computed(() => store.state.status);
                const qrCode = computed(() => store.state.qrCodeData);

                const statusColor = computed(() => {
                    if (currentStatus.value === 'CONNECTED') return 'success';
                    if (currentStatus.value === 'SCAN_QR') return 'warning';
                    if (currentStatus.value === 'CONNECTING') return 'info';
                    return 'error';
                });

                const statusIcon = computed(() => {
                    if (currentStatus.value === 'CONNECTED') return 'mdi-lan-connect';
                    if (currentStatus.value === 'SCAN_QR') return 'mdi-qrcode-scan';
                    if (currentStatus.value === 'CONNECTING') return 'mdi-sync';
                    return 'mdi-lan-disconnect';
                });

                const connectDevice = () => {
                    store.dispatch('initializeSession');
                };

                onMounted(() => {
                    store.dispatch('checkStatus');
                });

                onUnmounted(() => {
                    store.dispatch('stopPolling');
                });

                return {
                    sessionId,
                    currentStatus,
                    qrCode,
                    statusColor,
                    statusIcon,
                    connectDevice
                };
            }
        });

        app.use(store);
        app.use(vuetify);
        app.mount('#app');
    </script>
</body>

</html>
